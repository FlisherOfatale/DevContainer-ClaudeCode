{
  "name": "Claude Code",
  "build": { "dockerfile": "Dockerfile" },

  "customizations": {
    "vscode": {
      "extensions": ["Anthropic.claude-code"]
    }
  },

  // Bind-mount host OAuth credentials so you don't re-auth after rebuilds.
  // Run `claude` on your host once first to authenticate.
  "mounts": [
    "source=${localEnv:USERPROFILE}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=${localEnv:USERPROFILE}/.claude.json,target=/home/node/.claude.json,type=bind,consistency=cached"
  ],

  "remoteUser": "node"
}
